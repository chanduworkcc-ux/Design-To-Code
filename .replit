modules = ["web", "nodejs-20", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "PORT=18115 node artifacts/mobile/server/serve.js & MOBILE_PID=$!; trap 'kill $MOBILE_PID 2>/dev/null' EXIT SIGTERM SIGINT; PORT=5000 node --enable-source-maps artifacts/api-server/dist/index.mjs; wait"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/db run push && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/mobile run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mobile: expo"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && PORT=5000 MOBILE_PORT=18115 pnpm --filter @workspace/api-server run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3000
externalPort = 3000
