{
  "version": 2,
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": "artifacts/mobile/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api|_expo|assets|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/_expo/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
